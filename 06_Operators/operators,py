#Operators in python:
#Operators are special symbols that perform specific operations on operands.
#operands are the values on which the operators perform operations.


#01. Arithmetic Operators: These operators are used to perform mathematical operations on numbers.
print(10 + 5)#Addition operator
print(10 - 5)#Subtraction operator
print(10 * 5)#Multiplication operator
print(10 / 5)#Division operator
print(10 % 5)#Modulus operator
print(10 ** 5)#Exponentiation operator

#Precedence of arithmetic operators:
#1. Parentheses ()
#2. Exponentiation (**)
#3. Multiplication (*) and Division (/)
#4. Addition (+) and Subtraction (-)


#02. Comparison Operators: These operators are used to compare two values and return a boolean value (True or False).
print(10 > 5) #Greater than operator
print(10 < 5) #Less than operator
print(10 == 5) #Equal to operator
print(10 != 5) #Not equal to operator
print(10 >= 5) #Greater than or equal to operator
print(10 <= 5) #Less than or equal to operator


#03. Logical Operators: These operators are used to combine multiple boolean expressions and return a boolean value (True or False).
is_student = True
is_adult = False
print(is_student and is_adult) #Logical AND operator (when both operands are True, the result is True)
print(is_student or is_adult) #Logical OR operator (when at least one operand is True, the result is True)
print(not is_student) #Logical NOT operator (when the operand is True, the result is False and vice versa)


#04. Assignment Operators: These operators are used to assign values to variables.
age = 21 #Assignment operator

#methods of assignment operators:
age += 1 #age = age + 1
age -= 1 #age = age - 1
age *= 2 #age = age * 2
age /= 2 #age = age / 2
age %= 2 #age = age % 2
age **= 2 #age = age ** 2


